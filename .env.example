# ── ESG AI Copilot ────────────────────────────────────────────────────────────
# The Anthropic API key is a SERVER-ONLY secret. It must NEVER be given a VITE_
# prefix and must NEVER appear in the frontend bundle.
#
# Set it as a secret on the Supabase Edge Function (not in this file in prod):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
#   supabase secrets set ANTHROPIC_MODEL=claude-sonnet-4-20250514   # optional
#   supabase functions deploy esg-copilot
ANTHROPIC_API_KEY=

# Public (safe) URL of the deployed proxy the browser streams from.
# Only VITE_-prefixed vars are exposed to the client — this URL is not a secret.
VITE_COPILOT_ENDPOINT=

# Public anon key — only needed if the Edge Function keeps JWT verification ON.
VITE_SUPABASE_ANON_KEY=
